# ─────────────────────────────────────────────────────────────────────────────
# Android TV Background Generator — environment configuration
# Copy this file to .env (or config/.env) and fill in your values.
# Lines starting with # are comments and are ignored.
# ─────────────────────────────────────────────────────────────────────────────

# ── Docker / scheduling ───────────────────────────────────────────────────────
# How often to regenerate backgrounds (cron syntax). Default: every hour.
CRON_SCHEDULE=0 * * * *

# Path to this .env file inside the container (only needed when using config/.env)
# DOTENV_PATH=/app/config/.env

# ── Shared appearance ─────────────────────────────────────────────────────────
# Rendering style: "color" (blurred backdrop) or "overlay" (bckg.png + overlay.png)
BACKGROUND_STYLE=color

# Output image format and quality (jpg or png; quality 1–95, jpg only)
# OUTPUT_FORMAT=jpg
# OUTPUT_QUALITY=95

# Output canvas size in pixels
# CANVAS_WIDTH=3840
# CANVAS_HEIGHT=2160

# Vignette / blur tuning (color style only)
# VIGNETTE_FADE_RATIO=0.3
# VIGNETTE_FADE_POWER=2.5
# VIGNETTE_BLUR_RADIUS=60
# VIGNETTE_OFFSET_BOTTOM=150

# ── Collect directory ─────────────────────────────────────────────────────────
# When set, images from all services are copied into one flat directory after
# every run. Files are prefixed with the service name (e.g. jellyfin_Title.jpg)
# to avoid collisions. The directory is updated atomically once all services
# finish, so readers always see a complete snapshot.
# COLLECT_DIR=backgrounds/all

# ── Jellyfin ──────────────────────────────────────────────────────────────────
JELLYFIN_BASEURL=http://192.168.1.100:8096
JELLYFIN_TOKEN=your_jellyfin_api_token
JELLYFIN_USER_ID=your_jellyfin_user_id
# JELLYFIN_API_DELAY=1.0

# ── Plex ──────────────────────────────────────────────────────────────────────
PLEX_BASEURL=http://192.168.1.100:32400
PLEX_TOKEN=your_plex_token
# PLEX_API_DELAY=1.0

# ── Plex Friends ──────────────────────────────────────────────────────────────
# Reuses PLEX_TOKEN above. Set to true to enable.
# PLEX_FRIEND_ENABLED=false
# PLEXFRIEND_API_DELAY=1.0

# ── Radarr & Sonarr ───────────────────────────────────────────────────────────
RADARR_URL=http://192.168.1.100:7878
RADARR_API_KEY=your_radarr_api_key
SONARR_URL=http://192.168.1.100:8989
SONARR_API_KEY=your_sonarr_api_key
# DAYS_AHEAD=7
# RADARR_SONARR_LOGO=jellyfinlogo.png
# RADARRSONARR_API_DELAY=0.0

# ── TMDB (required for Radarr/Sonarr, Trakt, and the TMDB fallback) ───────────
TMDB_BEARER_TOKEN=your_tmdb_bearer_token
# TMDB_BASE_URL=https://api.themoviedb.org/3
# TMDB_IMG_BASE=https://image.tmdb.org/t/p/original
# TMDB_LANGUAGE=en-US

# TMDB standalone generator options
# NUMBER_OF_MOVIES=5
# NUMBER_OF_TV_SHOWS=5
# MAX_AGE_DAYS=90
# CUSTOM_TEXT=Now Trending on

# ── Trakt ─────────────────────────────────────────────────────────────────────
TRAKT_API_KEY=your_trakt_api_key
TRAKT_USERNAME=your_trakt_username
TRAKT_LISTNAME=your_list_name
# TRAKT_API_DELAY=0.0

# ── Lidarr ────────────────────────────────────────────────────────────────────
LIDARR_URL=http://192.168.1.100:8686
LIDARR_API_KEY=your_lidarr_api_key
# LIDARR_LOGO=lidarrlogo.png
# LIDARR_API_DELAY=0.5

# ── Steam ─────────────────────────────────────────────────────────────────────
STEAM_API_KEY=your_steam_api_key
STEAM_USER_ID=your_steam_user_id
# STEAM_LOGO=steamlogo.png
# STEAM_API_DELAY=0.5
